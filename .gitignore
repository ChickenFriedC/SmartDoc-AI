# Python virtual environments
### Python virtual environments
venv/
.venv/
env/
ENV/

### Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.ipynb_checkpoints/

### Build / test artifacts
build/
dist/
*.egg-info/
.tox/
.coverage
htmlcov/

### IDE
.vscode/
.idea/
*.swp
*.swo

### OS
.DS_Store
Thumbs.db

### Streamlit (never commit secrets)
.streamlit/secrets.toml

### Logs / reports
*.log
error.txt
performance_report.txt

### Secrets
.env

### Generated caches / vector stores (can be huge)
src/data/cache/
*.pkl
*.faiss
*.index
*.bin

### Data & docs
# Keep common document formats versioned by default.
!data/
!*.pdf
!*.docx
!*.pptx
